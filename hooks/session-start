#!/usr/bin/env bash
# SessionStart hook for the Salla Partners Agent Kit.
# Injects the Salla routing rule so Salla app tasks start with salla-app-expert
# (before generic brainstorming/planning from other plugins).

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Re-arm the soft UserPromptSubmit nudge for this fresh/cleared/compacted context.
rm -f "${TMPDIR:-/tmp}/salla-prompt-nudge.on" 2>/dev/null || true

context_raw=$(cat "${SCRIPT_DIR}/session-start-context.md" 2>/dev/null \
  || echo "Salla Partners Agent Kit: for Salla app development tasks, invoke salla-partners:salla-app-expert FIRST.")

# Escape for JSON embedding (single C-level pass each).
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

context_escaped=$(escape_for_json "$context_raw")
session_context="<EXTREMELY_IMPORTANT>\n${context_escaped}\n</EXTREMELY_IMPORTANT>"

# Emit only the field the current platform consumes (printf avoids the bash 5.3+
# heredoc hang). Cursor → additional_context; Claude Code → hookSpecificOutput;
# Copilot CLI / others → top-level additionalContext.
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$session_context"
fi

exit 0
