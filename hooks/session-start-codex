#!/usr/bin/env bash
# Codex SessionStart hook for the Salla Partners Agent Kit.
# Same routing rule as ./session-start, emitted in the format Codex consumes.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

context_raw=$(cat "${SCRIPT_DIR}/session-start-context.md" 2>&1 \
  || echo "Salla Partners Agent Kit: for Salla app development tasks, invoke salla-partners:salla-app-expert FIRST.")

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

context_escaped=$(escape_for_json "$context_raw")
session_context="<EXTREMELY_IMPORTANT>\n${context_escaped}\n</EXTREMELY_IMPORTANT>"

printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"

exit 0
